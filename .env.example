# === Client apps (generated by pnpm bootstrap:medusa or scripts/railway-init.sh) ===
EXPO_PUBLIC_MEDUSA_BASE=http://localhost:9000
EXPO_PUBLIC_MEDUSA_PUBLISHABLE_KEY=pk_from_bootstrap
NEXT_PUBLIC_SHC_API_BASE=http://localhost:9000
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=pk_from_bootstrap

# === Medusa backend (local docker-compose) ===
DATABASE_URL=postgres://shc:shc_dev@localhost:5432/shc_medusa
REDIS_URL=redis://localhost:6379
JWT_SECRET=change-me-in-production
COOKIE_SECRET=change-me-in-production
MEDUSA_DISABLE_ADMIN=true

# === Railway staging (set in Railway dashboard — never commit secrets) ===
# MEDUSA_PUBLIC_URL=https://<medusa-service>.up.railway.app
# RAILWAY_PUBLIC_DOMAIN=<medusa-service>.up.railway.app
# WEB_PUBLIC_URL=https://<web-service>.up.railway.app
# RAILWAY_RUN_SEED=true   # first medusa deploy only
# STORE_CORS=https://<web-service>.up.railway.app,http://localhost:8081,http://localhost:3001
# AUTH_CORS=https://<web-service>.up.railway.app,http://localhost:8081,http://localhost:8082,http://localhost:3001

# === EAS preview builds ===
# EXPO_PUBLIC_MEDUSA_BASE=https://<medusa-service>.up.railway.app

# === Optional ===
MAESTRO_CLOUD_TOKEN=