{
  "name": "mobile",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build": "tsc --noEmit",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "echo 'Maestro E2E or jest here' && exit 0",
    "eas:build:dev": "npx eas build --profile development --platform all",
    "eas:build:preview": "npx eas build --profile preview --platform all",
    "eas:build:prod": "npx eas build --profile production --platform all",
    "eas:submit:ios": "npx eas submit --platform ios --profile production",
    "eas:submit:android": "npx eas submit --platform android --profile production",
    "export": "expo export"
  },
  "dependencies": {
    "@shc/types": "workspace:*",
    "@shc/ui": "workspace:*",
    "@shc/utils": "workspace:*",
    "@shc/business-rules": "workspace:*",
    "@gluestack-ui/themed": "^1.1.73",
    "@gluestack-style/react": "^1.0.57",
    "expo": "~51.0.0",
    "expo-constants": "~16.0.0",
    "expo-font": "~12.0.0",
    "expo-linking": "~6.3.1",
    "expo-router": "~3.5.0",
    "expo-splash-screen": "~0.27.0",
    "expo-status-bar": "~1.12.1",
    "expo-secure-store": "~13.0.0",
    "@tanstack/react-query": "^5.0.0",
    "react": "18.2.0",
    "react-native": "0.74.0",
    "react-native-safe-area-context": "4.10.0",
    "react-native-screens": "3.31.1",
    "react-native-svg": "15.2.0",
    "zod": "^3.23.8",
    "@babel/runtime": "^7.24.0"
  },
  "devDependencies": {
    "@types/react": "~18.2.79",
    "typescript": "~5.3.3",
    "eslint": "^9.0.0"
  },
  "expo": {
    "install": {
      "exclude": []
    }
  }
}
