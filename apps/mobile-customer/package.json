{
  "name": "mobile-customer",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build": "tsc --noEmit",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "echo 'Maestro E2E or jest here' && exit 0",
    "eas:build:dev": "npx eas build --profile development --platform all",
    "eas:build:preview": "npx eas build --profile preview --platform all",
    "eas:build:prod": "npx eas build --profile production --platform all",
    "eas:submit:ios": "npx eas submit --platform ios --profile production",
    "eas:submit:android": "npx eas submit --platform android --profile production",
    "export": "expo export"
  },
  "dependencies": {
    "@babel/runtime": "^7.24.0",
    "@expo/vector-icons": "^14.1.0",
    "@gluestack-style/react": "^1.0.57",
    "@gluestack-ui/themed": "^1.1.73",
    "@shc/api-client": "workspace:*",
    "@shc/business-rules": "workspace:*",
    "@shc/types": "workspace:*",
    "@shc/ui": "workspace:*",
    "@shc/utils": "workspace:*",
    "@shopify/flash-list": "1.6.4",
    "@shopify/react-native-skia": "1.2.3",
    "@tamagui/config": "^1.144.4",
    "@tamagui/core": "^1.144.4",
    "@tanstack/react-query": "^5.0.0",
    "expo": "~51.0.0",
    "expo-constants": "~16.0.0",
    "expo-font": "~12.0.0",
    "expo-device": "~6.0.2",
    "expo-linking": "~6.3.1",
    "expo-notifications": "~0.28.19",
    "expo-router": "~3.5.0",
    "expo-secure-store": "~13.0.0",
    "expo-splash-screen": "~0.27.0",
    "expo-status-bar": "~1.12.1",
    "moti": "^0.29.0",
    "nativewind": "^4.2.5",
    "react": "18.2.0",
    "react-native": "0.74.0",
    "react-native-css-interop": "^0.2.5",
    "react-native-gesture-handler": "~2.16.2",
    "react-native-reanimated": "~3.10.1",
    "react-native-safe-area-context": "4.10.0",
    "react-native-screens": "3.31.1",
    "react-native-svg": "15.2.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@babel/plugin-transform-class-static-block": "^7.29.7",
    "@types/react": "~18.2.79",
    "eslint": "^9.0.0",
    "metro-cache": "0.80.12",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.3.3"
  },
  "expo": {
    "install": {
      "exclude": []
    }
  }
}
