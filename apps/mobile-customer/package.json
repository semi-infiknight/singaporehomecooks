{
  "name": "mobile-customer",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build": "echo 'Expo source-only (Maestro E2E on macOS CI)' && exit 0",
    "lint": "eslint .",
    "typecheck": "echo 'Expo source-only (Maestro E2E on macOS CI)' && exit 0",
    "test": "echo 'Maestro E2E or jest here' && exit 0",
    "eas:build:dev": "npx eas build --profile development --platform all",
    "eas:build:preview": "npx eas build --profile preview --platform all",
    "eas:build:prod": "npx eas build --profile production --platform all",
    "eas:submit:ios": "npx eas submit --platform ios --profile production",
    "eas:submit:android": "npx eas submit --platform android --profile production",
    "export": "expo export",
    "eas-build-post-install": "cd ../.. && pnpm --filter @shc/types build && pnpm --filter @shc/business-rules build && pnpm --filter @shc/api-client build"
  },
  "dependencies": {
    "@babel/runtime": "^7.24.0",
    "@expo/vector-icons": "^15.1.1",
    "@gluestack-style/react": "^1.0.57",
    "@gluestack-ui/themed": "^1.1.73",
    "@react-native/assets-registry": "0.81.5",
    "@shc/api-client": "workspace:*",
    "@shc/business-rules": "workspace:*",
    "@shc/types": "workspace:*",
    "@shc/ui": "workspace:*",
    "@shc/utils": "workspace:*",
    "@shopify/flash-list": "2.0.2",
    "@shopify/react-native-skia": "2.2.12",
    "@tamagui/config": "^1.144.4",
    "@tamagui/core": "^1.144.4",
    "@tanstack/react-query": "^5.0.0",
    "babel-preset-expo": "~54.0.11",
    "expo": "~54.0.35",
    "expo-asset": "~12.0.13",
    "expo-constants": "~18.0.13",
    "expo-device": "~8.0.10",
    "expo-font": "~14.0.12",
    "expo-linking": "~8.0.12",
    "expo-location": "^19.0.8",
    "expo-notifications": "~0.32.17",
    "expo-router": "~6.0.24",
    "expo-secure-store": "~15.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "moti": "^0.29.0",
    "nativewind": "^4.2.5",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-css-interop": "^0.2.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-maps": "1.20.1",
    "react-native-reanimated": "~4.1.7",
    "react-native-safe-area-context": "5.6.2",
    "react-native-screens": "4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-worklets": "0.5.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@babel/plugin-transform-class-static-block": "^7.29.7",
    "@types/react": "~19.1.17",
    "eslint": "^9.0.0",
    "metro": "0.83.3",
    "metro-cache": "0.83.3",
    "metro-config": "0.83.3",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.9.3"
  },
  "expo": {
    "install": {
      "exclude": []
    }
  }
}
