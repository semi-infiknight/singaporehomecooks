{
  "expo": {
    "name": "SHC Customer",
    "slug": "shc-customer",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFF8F0"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.singaporehomecooks.customer",
      "entitlements": {
        "aps-environment": "production"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#D96C4A"
      },
      "package": "com.singaporehomecooks.customer",
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro",
      "display": "standalone",
      "themeColor": "#D96C4A",
      "backgroundColor": "#FFF8F0",
      "name": "Singapore Home Cooks",
      "shortName": "SHC Home Cooks",
      "description": "Heritage home-cooked SG dishes for occasions. HDB kitchens, trust-first."
    },
    "plugins": [
      "expo-router",
      "expo-notifications",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Singapore Home Cooks uses your location to show home cooks near your HDB collection point."
        }
      ],
      "expo-asset",
      "expo-font",
      "expo-secure-store"
    ],
    "scheme": "shc-customer",
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "5c1f4300-5851-4288-9416-bd968589001a"
      }
    },
    "owner": "darksend"
  }
}
