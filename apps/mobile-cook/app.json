{
  "expo": {
    "name": "SHC Cook",
    "slug": "shc-cook",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFF8F0"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.singaporehomecooks.cook",
      "entitlements": {
        "aps-environment": "production"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#D96C4A"
      },
      "package": "com.singaporehomecooks.cook"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro",
      "display": "standalone",
      "themeColor": "#D96C4A",
      "backgroundColor": "#FFF8F0",
      "name": "Singapore Home Cooks Cook",
      "shortName": "SHC Cook",
      "description": "Cook dashboard for Singapore Home Cooks — orders, listings, and compliance."
    },
    "plugins": [
      "expo-router",
      "expo-notifications",
      "expo-asset",
      "expo-font",
      "expo-secure-store"
    ],
    "scheme": "shc-cook",
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "bb1c9052-df53-48fd-89e2-94ee51159bd9"
      }
    },
    "owner": "darksend"
  }
}
