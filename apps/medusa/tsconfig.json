{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "declaration": false,
    "declarationMap": false,
    "outDir": "./dist",
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "@medusajs/*": ["node_modules/@medusajs/*"],
      "@shc/types": ["../../packages/shc-types/dist"],
      "@shc/business-rules": ["../../packages/business-rules/dist"]
    },
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true
  },
  "include": ["src/**/*", "medusa-config.ts", "scripts/**/*"],
  "exclude": ["node_modules", "dist", "build"]
}
